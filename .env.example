# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aicfo
DB_PORT=5432

# Redis Configuration
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET=your-super-secret-key-min-32-characters-long!!
JWT_ISSUER=ai-cfo
JWT_AUDIENCE=ai-cfo-api

# Bank Integration (Flutterwave)
FLUTTERWAVE_CLIENT_ID=your-flutterwave-client-id
FLUTTERWAVE_CLIENT_SECRET=your-flutterwave-client-secret
FLUTTERWAVE_REDIRECT_URI=http://localhost:3000/oauth/callback

# API Configuration
API_PORT=8080
ASPNETCORE_ENVIRONMENT=Production

# Frontend URLs (for CORS)
FRONTEND_URL_LOCAL=http://localhost:3000
FRONTEND_URL_PROD=https://your-frontend-domain.com

# Email Configuration (for Phase 5.2 reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
